# Review Request Automation - Phase 0 integration placeholders only
# Do not paste real secrets into this file. Copy needed values into a local .env
# only after the matching integration has been approved and confirmed.

REVIEW_REQUEST_AUTOMATION_ENABLED=false
REVIEW_REQUEST_PHASE=0
REVIEW_REQUEST_DRY_RUN=true
REVIEW_REQUEST_REPORT_ONLY=true

# Ali Reviews / Kudosi API
ALI_REVIEWS_API_DOCS_CONFIRMED=false
ALI_REVIEWS_API_BASE_URL=
ALI_REVIEWS_API_TOKEN=
KUDOSI_API_DOCS_CONFIRMED=false
KUDOSI_API_BASE_URL=https://pub.kudosi.ai
KUDOSI_API_KEY=

# Shopify Admin API tag write preparation
SHOPIFY_REVIEW_REQUEST_TAG_WRITE_CONFIRMED=false
SHOPIFY_REVIEW_REQUEST_REQUIRED_SCOPES=write_orders,write_customers
SHOPIFY_REVIEW_REQUEST_SENT_TAG=
SHOPIFY_REVIEW_REQUEST_SUPPRESSED_TAG=

# Gmail API send preparation for info@kidstoylover.com
GMAIL_REVIEW_REQUEST_OAUTH_CONFIRMED=false
GMAIL_REVIEW_REQUEST_SEND_PERMISSION_CONFIRMED=false
GMAIL_REVIEW_REQUEST_FROM_ADDRESS=info@kidstoylover.com
GMAIL_SEND_FROM=info@kidstoylover.com
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send

# Trustpilot review link
TRUSTPILOT_REVIEW_LINK_CONFIRMED=false
TRUSTPILOT_REVIEW_LINK=

# Ticket system filtering rules
REVIEW_REQUEST_TICKET_FILTERS_CONFIRMED=false
REVIEW_REQUEST_TICKET_ALLOWED_STATUSES=
REVIEW_REQUEST_TICKET_EXCLUDED_TAGS=
